{
  "scopeName": "source.c4",
  "name": "C4",
  "fileTypes": ["c4"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#numbers" },
    { "include": "#strings" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.c4",
          "match": "//.*$"
        },
        {
          "name": "comment.block.c4",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.c4",
          "match": "\\b(fn|struct|return|if|elif|else|while|loop|break|continue|foreign|pub|static|naked|as)\\b"
        },
        {
          "name": "constant.language.boolean.c4",
          "match": "\\b(true|false)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.c4",
          "match": "\\b(bool|char|void|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|str)\\b"
        },
        {
          "name": "storage.type.user.c4",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.c4",
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
          "name": "support.function.call.c4",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.c4",
          "match": "\\b(0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|\\d+\\.\\d+|\\d+)\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.c4",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.c4",
          "begin": "'",
          "end": "'"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.c4",
          "match": "(\\+|\\-|\\*|\\/|%|==|!=|<=|>=|<|>|&&|\\|\\||!|=|\\+=|-=|\\*=|/=|%=|&|\\||\\^|~|<<|>>)"
        }
      ]
    }
  }
}